# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend
RESEND_API_KEY=re_your_api_key
RESEND_TO_EMAIL=contact@yourdomain.com

# Site
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# Sanity — project ID + dataset from sanity.io/manage (public, safe to expose)
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
# Editor-level API token from sanity.io/manage -> API -> Tokens. Server-only — never prefix with NEXT_PUBLIC_.
SANITY_API_TOKEN=
# Shared secret for the /api/revalidate webhook. Generate with: openssl rand -hex 32
SANITY_REVALIDATION_SECRET=
